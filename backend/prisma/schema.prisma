// Prisma schema for Camel. SQLite provider; single `dev.db` file per Phase 1.
// Regenerate the client with `npx prisma generate` after edits, and create
// migrations with `npx prisma migrate dev --name <change>`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  email        String?  @unique
  displayName  String?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  authEvents   AuthEvent[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model AuthEvent {
  id        String   @id @default(uuid())
  userId    String?
  username  String?
  eventType String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_auth_events_user_createdAt")
  @@index([username, createdAt], map: "idx_auth_events_username_createdAt")
  @@map("auth_events")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  jti        String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], map: "idx_refresh_tokens_user_revoked")
  @@map("refresh_tokens")
}
